# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=medpolicy
POSTGRES_PASSWORD=medpolicy123
POSTGRES_DB=medpolicydb
DATABASE_URL=postgresql://medpolicy:medpolicy123@localhost:5432/medpolicydb

# ─── Auth0 ────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://your-api-audience
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# ─── Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── LlamaParse ───────────────────────────────────────────
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key

# ─── RxNorm (no key needed, public API) ───────────────────
RXNORM_API_BASE=https://rxnav.nlm.nih.gov/REST

# ─── App ──────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
